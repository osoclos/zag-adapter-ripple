{
    "name": "zag-adapter-ripple",
    "version": "0.1.0",
    "description": "A Zag.js framework adapter for Ripple.ts (v0.3.0)",

    "homepage": "https://github.com/osoclos/zag-adapter-ripple",

    "license": "MIT",
    "author": {
        "name": "osoclos",
        "email": "osoclosus@gmail.com",

        "url": "https://github.com/osoclos"
    },

    "repository": {
        "type": "git",
        "url": "git+https://github.com/osoclos/zag-adapter-ripple.git"
    },

    "bugs": {
        "email": "osoclosus@gmail.com",
        "url": "https://github.com/osoclos/zag-adapter-ripple/issues"
    },

    "private": false,

    "type": "module",

    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",

    "files": ["dist"],
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },

    "scripts": {
        "dev": "concurrently \"tsdown --watch\" \"vitest watch\"",

        "build": "tsdown",
        "test": "vitest",

        "bump": "tsdown && bumpp"
    },

    "peerDependencies": {
        "@zag-js/core": ">=1.0.0",
        "@zag-js/utils": ">=1.0.0",

        "ripple": ">=0.3.0"
    },

    "devDependencies": {
        "tsdown": "^0.22.2",

        "vitest": "^4.1.8",
        "@vitest/browser-preview": "^4.1.8",

        "typescript": "^6.0.3",

        "@types/node": "^25.9.3",

        "bumpp": "^11.1.0",
        "concurrently": "^10.0.3"
    }
}
